% --- Theme options (set via `\usetheme[...]{UPES}`) -------------------------------
% Overall palette (all aspects at once)
\DeclareOptionBeamer{palette}[scheme01-classic-teal]{\UPESSetPalette{#1}}
\DeclareOptionBeamer{scheme}[scheme01-classic-teal]{\UPESSetPalette{#1}}

% Individual aspect selection (mix-and-match)
\DeclareOptionBeamer{headerfooter}[brand-blue]{\UPESSetHeaderFooterScheme{#1}}
\DeclareOptionBeamer{hf}[brand-blue]{\UPESSetHeaderFooterScheme{#1}}
\DeclareOptionBeamer{heading}[teal]{\UPESSetHeadingScheme{#1}}
\DeclareOptionBeamer{frametitle}[teal]{\UPESSetHeadingScheme{#1}}
\DeclareOptionBeamer{bodyheadings}[brand-blue]{\UPESSetBodyHeadingsScheme{#1}}
\DeclareOptionBeamer{structure}[brand-blue]{\UPESSetBodyHeadingsScheme{#1}}
\DeclareOptionBeamer{bodytext}[graphite]{\UPESSetBodyTextScheme{#1}}
\DeclareOptionBeamer{text}[graphite]{\UPESSetBodyTextScheme{#1}}

\ProcessOptionsBeamer
% Keep `@` as a letter for the rest of the theme file (we define many internal
% lengths/macros like `\UPES@safeleft` and also use `\define@key`). We switch
% back to normal catcodes at the very end of the package.
  
\mode<presentation>

% Use the same navigation model as the reference deck (`major-project-2026-beamer.pdf`).
% `subsection=false` keeps the top navigation slim (no extra subsection row).
\useoutertheme[subsection=false]{miniframes}

% --- Background image ---
% Background is always `upes-background.jpeg`.
%
% NOTE:
% `upes-header-footer.jpeg` and `upes-headings.jpeg` are design references for
% color/positioning of the header/footer and heading bar, not slide backgrounds.
\setbeamertemplate{background canvas}{%
  \IfFileExists{UPES-Beamer-Theme/upes-background.jpeg}{%
    \includegraphics[width=\paperwidth,height=\paperheight]{UPES-Beamer-Theme/upes-background.jpeg}%
  }{%
    \IfFileExists{upes-background.jpeg}{%
      \includegraphics[width=\paperwidth,height=\paperheight]{upes-background.jpeg}%
    }{}%
  }%
}

% --- Typography / structure ---
\setbeamerfont{title}{family=\rmfamily,series=\bfseries,size=\Huge}
\setbeamerfont{subtitle}{family=\rmfamily,series=\bfseries,size=\LARGE}
\setbeamerfont{frametitle}{series=\bfseries,size=\Large}
% Keep header/footer slim (closer to the reference deck).
\setbeamerfont{footline}{size=\tiny}
\setbeamerfont{author in head/foot}{size=\tiny}
\setbeamerfont{title in head/foot}{size=\tiny}
\setbeamerfont{institute in head/foot}{size=\tiny}
\setbeamerfont{page number in head/foot}{size=\tiny}
\setbeamerfont{section in head/foot}{series=\mdseries,size=\scriptsize}

% Remove navigation symbols
\setbeamertemplate{navigation symbols}{}

% Apply the default palette now (can be overridden later via \UPESSetPalette{...}).
\UPESApplyPalette
 
% ------------------------------------------------------------------------------
% Safe content region (keeps headline/footline/text inside the white area).
% ------------------------------------------------------------------------------
\newlength{\UPES@safeleft}
\newlength{\UPES@saferight}
\newlength{\UPES@pad}
\newlength{\UPES@textleft}
\newlength{\UPES@textwidth}
\newlength{\UPES@contentwidth}
\newlength{\UPES@headtop}
\newlength{\UPES@headbar}
\newlength{\UPES@headheight}
\newlength{\UPES@footbar}
\newlength{\UPES@foottopgap}
\newlength{\UPES@footbottom}
\newlength{\UPES@footheight}
\newlength{\UPES@titlegap}
\newlength{\UPES@titlebarheight}
\newlength{\UPES@titleleft}
\newlength{\UPES@titlewidth}
\newlength{\UPES@titlepad}
\newdimen\UPES@frametopmargin
\newdimen\UPES@framebottommargin

% Defaults tuned from the working (aligned) deck in:
%   D:\InSync-tofik\Work\UPES\Project-Mentoship\2026-Spring
% Keep all overlaid text safely inside the white region (away from the left
% gradient strip + bottom curve). Background bars extend further left, but we
% intentionally start text at the footer bar start (keeps white text fully on
% the blue bar in `upes-header-footer.jpeg`).
\setlength{\UPES@safeleft}{0.097\paperwidth} % ~310/3200
\setlength{\UPES@saferight}{0.020\paperwidth}
\setlength{\UPES@pad}{0.40cm}

% Vertical layout (reserve space so text stays in the white region)
\setlength{\UPES@headtop}{0.0133\paperheight}    % ~24/1800
\setlength{\UPES@headbar}{0.0811\paperheight}    % ~146/1800
\setlength{\UPES@headheight}{0.0944\paperheight} % ~170/1800

\setlength{\UPES@footbar}{0.0667\paperheight}    % ~120/1800 (blue footer bar height)
\setlength{\UPES@footbottom}{0.0111\paperheight} % ~20/1800 (bottom padding)
% Reserve extra vertical space above the footer so body text never overlaps the
% orange accent line (~y=1570..1600 in the 1800px-tall reference images).
\setlength{\UPES@footheight}{0.1278\paperheight} % ~230/1800
\setlength{\UPES@foottopgap}{\dimexpr\UPES@footheight-\UPES@footbar-\UPES@footbottom\relax}

\setlength{\UPES@titlegap}{0.0100\paperheight}   % ~18/1800 (gap below header bar)
\setlength{\UPES@titlebarheight}{0.0756\paperheight} % ~136/1800
\setlength{\UPES@titlepad}{0.55cm}

\setlength{\UPES@contentwidth}{\paperwidth}
\addtolength{\UPES@contentwidth}{-\UPES@safeleft}
\addtolength{\UPES@contentwidth}{-\UPES@saferight}

\setbeamersize{%
  text margin left=\dimexpr\UPES@safeleft+\UPES@pad\relax,
  text margin right=\dimexpr\UPES@saferight+\UPES@pad\relax
}

% Text region (the area where slide text is allowed to appear).
\setlength{\UPES@textleft}{\dimexpr\UPES@safeleft+\UPES@pad\relax}
\setlength{\UPES@textwidth}{\dimexpr\UPES@contentwidth-2\UPES@pad\relax}

% Frame title (heading box): fixed size, centered to the text region.
% This keeps the heading box alignment stable even if margins are tuned later.
\setlength{\UPES@titlewidth}{\dimexpr\UPES@textwidth*94/100\relax}
\setlength{\UPES@titleleft}{\dimexpr(\UPES@textwidth-\UPES@titlewidth)/2\relax}

% Frame content margins (space between heading box and content, and above footer).
% Implemented via Beamer's frame top/bottom skips so it applies to every slide.
\setlength{\UPES@frametopmargin}{0.30cm}
\setlength{\UPES@framebottommargin}{0.30cm}

% Patch Beamer's vertical alignment keys to always include the above margins.
% (Beamer resets these skips at the start of every frame via the {c}/{t}/{b}/{s} keys.)
\define@key{beamerframe}{c}[true]{% centered
  % Add shrink components so dense frames can still fit without being cut off.
  \beamer@frametopskip=\UPES@frametopmargin plus 1fill minus \UPES@frametopmargin\relax%
  \beamer@framebottomskip=\UPES@framebottommargin plus 1.5fill minus \UPES@framebottommargin\relax%
  \beamer@frametopskipautobreak=\UPES@frametopmargin plus .4\paperheight minus \UPES@frametopmargin\relax%
  \beamer@framebottomskipautobreak=\UPES@framebottommargin plus .6\paperheight minus \UPES@framebottommargin\relax%
}
\define@key{beamerframe}{t}[true]{% top
  \beamer@frametopskip=\UPES@frametopmargin plus .5\paperheight minus \UPES@frametopmargin\relax%
  \beamer@framebottomskip=\UPES@framebottommargin plus 1fill minus \UPES@framebottommargin\relax%
  \beamer@frametopskipautobreak=\beamer@frametopskip\relax%
  \beamer@framebottomskipautobreak=\beamer@framebottomskip\relax%
}
\define@key{beamerframe}{b}[true]{% bottom
  \beamer@frametopskip=\UPES@frametopmargin plus 1fill minus \UPES@frametopmargin\relax%
  \beamer@framebottomskip=\UPES@framebottommargin minus \UPES@framebottommargin\relax%
  \beamer@frametopskipautobreak=\beamer@frametopskip\relax%
  \beamer@framebottomskipautobreak=\beamer@framebottomskip\relax%
}
\define@key{beamerframe}{s}[true]{% stretch
  \beamer@frametopskip=\UPES@frametopmargin\relax%
  \beamer@framebottomskip=\UPES@framebottommargin plus 0.001fill minus \UPES@framebottommargin\relax%
  \beamer@frametopskipautobreak=\beamer@frametopskip\relax%
  \beamer@framebottomskipautobreak=\beamer@framebottomskip\relax%
}

% ------------------------------------------------------------------------------
% Title / Cover / Thank-You frames (styled to match Unit1_IntroToOS.pdf)
% ------------------------------------------------------------------------------

\defbeamertemplate*{title page}{UPES}{%
  \vbox{}%
  % NOTE: Do not add an extra `\hskip\UPES@safeleft` here; the frame content is
  % already constrained by `\setbeamersize{text margin left/right=...}`.
  \begingroup
  \setlength{\parskip}{0pt}%
  \vspace*{0.05cm}%

  % Title block (match the reference deck): centered box inside the white text region.
  \hbox{%
    \hskip\UPES@titleleft%
    \begin{beamercolorbox}[wd=\UPES@titlewidth,sep=0.25cm,center]{frametitle}%
      {\rmfamily\bfseries\usebeamercolor[fg]{frametitle}\fontsize{16}{19}\selectfont%
        \inserttitle\par}%
      \vspace{0.06cm}%
      {\rmfamily\bfseries\usebeamercolor[fg]{frametitle}\fontsize{10.5}{12.5}\selectfont%
        \insertsubtitle\par}%
    \end{beamercolorbox}%
  }%

  \vspace{0.30cm}%

  \begin{center}
    {\small\insertauthor\par}%
    \vspace{0.12cm}%
    {\scriptsize\insertinstitute\par}%
  \end{center}

  \vfill

  \begin{center}
    {\small\insertdate\par}%
  \end{center}

  \vspace*{0.05cm}%
  \endgroup
}
\setbeamertemplate{title page}[UPES]

\newcommand{\UPESCoverFrame}{%
  {%
    \setbeamertemplate{headline}{}%
    \setbeamertemplate{footline}{}%
    \setbeamertemplate{background canvas}{%
      \IfFileExists{UPES-Beamer-Theme/upes-first-page.jpeg}{%
        \includegraphics[width=\paperwidth,height=\paperheight]{UPES-Beamer-Theme/upes-first-page.jpeg}%
      }{%
        \IfFileExists{upes-first-page.jpeg}{%
          \includegraphics[width=\paperwidth,height=\paperheight]{upes-first-page.jpeg}%
        }{%
          \IfFileExists{UPES-Beamer-Theme/upes-first-page.png}{%
            \includegraphics[width=\paperwidth,height=\paperheight]{UPES-Beamer-Theme/upes-first-page.png}%
          }{%
            \IfFileExists{upes-first-page.png}{%
              \includegraphics[width=\paperwidth,height=\paperheight]{upes-first-page.png}%
            }{%
              \IfFileExists{UPES-Beamer-Theme/upes-cover.png}{%
                \includegraphics[width=\paperwidth,height=\paperheight]{UPES-Beamer-Theme/upes-cover.png}%
              }{%
                \IfFileExists{upes-cover.png}{%
                  \includegraphics[width=\paperwidth,height=\paperheight]{upes-cover.png}%
                }{}%
              }%
            }%
          }%
        }%
      }%
    }%
    \begin{frame}[plain]\end{frame}%
  }%
}

\newcommand{\UPESThankYouFrame}{%
  {%
    \setbeamertemplate{headline}{}%
    \setbeamertemplate{footline}{}%
    \begin{frame}[plain]
      \vfill
      \centering
      \IfFileExists{UPES-Beamer-Theme/upes-logo.png}{%
        \includegraphics[height=2.2cm]{UPES-Beamer-Theme/upes-logo.png}\par
      }{%
        \IfFileExists{upes-logo.png}{%
          \includegraphics[height=2.2cm]{upes-logo.png}\par
        }{}%
      }{}%
      \vspace{0.7cm}%
      {\rmfamily\bfseries\color{UPESBlueDark}\fontsize{46}{52}\selectfont Thank You\par}%
      \vfill
    \end{frame}%
  }%
}

\setbeamertemplate{headline}{%
  % Header navigation aligned to the blue header bar in upes-*.jpeg
  % (and constrained to the white safe region, so it doesn't overlap the gradient strip).
  \makeatletter
  \leavevmode%
  \hbox{%
    \hskip\UPES@safeleft%
    \vbox to \UPES@headheight{%
      \vskip\UPES@headtop%
      \begin{beamercolorbox}[wd=\UPES@contentwidth,sep=0pt]{section in head/foot}%
        \vbox to \UPES@headbar{%
          \vfil%
          \hbox to \UPES@contentwidth{%
            \hskip\UPES@pad%
            {%
              \usebeamerfont{section in head/foot}%
              \usebeamercolor[fg]{section in head/foot}%
              \begingroup\beamer@compresstrue%
                \insertnavigation{\dimexpr\UPES@contentwidth-2\UPES@pad\relax}%
              \endgroup%
            }%
            \hskip\UPES@pad%
          }%
          \vfil%
        }%
      \end{beamercolorbox}%
      \vfil%
    }%
  }%
  \makeatother
}

% Footer (2-line): author + institute (top), title + page number (bottom)
\setbeamertemplate{footline}{%
  \leavevmode%
  \hbox{%
    \hskip\UPES@safeleft%
    \vbox to \UPES@footheight{%
      \vskip\UPES@foottopgap%
      \begin{beamercolorbox}[wd=\UPES@contentwidth,sep=0pt]{author in head/foot}%
        \vbox to \UPES@footbar{%
          \vfil%
          \hbox to \UPES@contentwidth{%
            \hskip\UPES@pad%
            {\usebeamerfont{author in head/foot}\usebeamercolor[fg]{author in head/foot}\insertshortauthor}%
            \hfill%
            {\usebeamerfont{institute in head/foot}\usebeamercolor[fg]{institute in head/foot}\insertshortinstitute}%
            \hskip\UPES@pad%
          }%
          \vskip0.35ex%
          \hbox to \UPES@contentwidth{%
            \hskip\UPES@pad%
            {\usebeamerfont{title in head/foot}\usebeamercolor[fg]{title in head/foot}\insertshorttitle}%
            \hfill%
            {\usebeamerfont{page number in head/foot}\usebeamercolor[fg]{page number in head/foot}\usebeamertemplate{page number in head/foot}}%
            \hskip\UPES@pad%
          }%
          \vfil%
        }%
      \end{beamercolorbox}%
      \vskip\UPES@footbottom%
      \vfil%
    }%
  }%
}

% Frame title aligned with the same safe region.
\defbeamertemplate*{frametitle}{UPES}{%
  \nointerlineskip%
  \vskip\UPES@titlegap%
  \hbox{%
    \hskip\UPES@titleleft%
    \begin{beamercolorbox}[wd=\UPES@titlewidth,sep=0pt]{frametitle}%
      \vbox to \UPES@titlebarheight{%
        \vfil%
        \hbox to \UPES@titlewidth{%
          \hfil%
          {\usebeamerfont{frametitle}\usebeamercolor[fg]{frametitle}\insertframetitle}%
          \hfil%
        }%
        \vfil%
      }%
    \end{beamercolorbox}%
  }%
}
\setbeamertemplate{frametitle}[UPES]

% Orange bullets
\setbeamertemplate{itemize item}{\color{UPESOrange}$\bullet$}
\setbeamertemplate{itemize subitem}{\color{UPESOrange}$\circ$}

\mode<all>
\makeatother
