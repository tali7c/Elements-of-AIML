% ==============================================================================
% beamerthemeUPES.sty  -- UPES B.Tech Academic Presentation Theme
% Uses background image with left gradient bar + bottom accent line.
% All content is kept inside the white region by restricting headline/footline/
% frametitle to a safe region and setting text margins accordingly.
% ==============================================================================

\ProvidesPackage{beamerthemeUPES}[2026/02/10 UPES beamer theme]

\RequirePackage{graphicx}
\RequirePackage{xcolor}

% --- Brand-ish colors (picked to match the supplied background) ---
% NOTE: `UPESBlueDark` is sampled from `upes-header-footer.jpeg`.
\definecolor{UPESBlueDark}{HTML}{2B4693}
\definecolor{UPESBlue}{HTML}{177291}     % teal-dark accent (used sparingly)
\definecolor{UPESOrange}{HTML}{F28C28}
\definecolor{UPESLightBlue}{RGB}{70,175,249} % sampled from Unit1_IntroToOS title text
\definecolor{UPESHeadingYellow}{HTML}{FDCE4A} % sampled from `upes-headings.jpeg` heading bar
\definecolor{UPESBodyFG}{HTML}{111827} % default main text color (graphite)
\colorlet{UPESHeaderFooterBG}{UPESBlueDark} % header + footer bar background
\colorlet{UPESHeadingBG}{UPESBlue} % slide heading (frametitle) bar background
\colorlet{UPESBodyHeadingFG}{UPESBlueDark} % headings inside slide body (blocks/structure)

% --- Palette control (optional) --------------------------------------------------
% Usage (in your .tex):
%   \usetheme[palette=scheme01-classic-teal]{UPES}   % recommended
% or (after `\usetheme{UPES}`):
%   \UPESSetPalette{scheme01-classic-teal}
%
% This affects header/footer bars, heading (frametitle) bar, and text colors.
% The slide background image remains `upes-background.jpeg`.
\colorlet{UPESBarFG}{white}
\colorlet{UPESBarFGInactive}{white!85}
\colorlet{UPESFrameTitleFG}{white}

\newcommand{\UPESApplyPalette}{%
  % Core accents
  \setbeamercolor{normal text}{fg=UPESBodyFG}%
  \setbeamercolor{author}{fg=UPESBodyFG}%
  \setbeamercolor{institute}{fg=UPESBodyFG}%
  \setbeamercolor{date}{fg=UPESBodyFG}%
  \setbeamercolor{alerted text}{fg=UPESOrange}%
  \setbeamercolor{example text}{fg=UPESBodyHeadingFG}%
  \setbeamercolor{structure}{fg=UPESBodyHeadingFG}%
  % Make ToC readable on projectors (avoid low-contrast accent-colored text).
  \setbeamercolor{section in toc}{fg=UPESBodyFG}%
  \setbeamercolor{subsection in toc}{fg=UPESBodyFG}%
  \setbeamercolor{subsubsection in toc}{fg=UPESBodyFG}%
  % Keep list markers as the primary accent.
  \setbeamercolor{itemize item}{fg=UPESOrange}%
  \setbeamercolor{itemize subitem}{fg=UPESOrange}%
  \setbeamercolor{enumerate item}{fg=UPESOrange}%
  \setbeamercolor{enumerate subitem}{fg=UPESOrange}%
  \setbeamercolor{frametitle}{fg=UPESFrameTitleFG,bg=UPESHeadingBG}%
  \setbeamercolor{title}{fg=UPESLightBlue}%
  \setbeamercolor{subtitle}{fg=UPESLightBlue}%
  % Blocks (keep subtle; readable on the white region)
  \setbeamercolor{block title}{fg=UPESBodyHeadingFG,bg=UPESBodyHeadingFG!12}%
  \setbeamercolor{block body}{fg=UPESBodyFG,bg=UPESBodyHeadingFG!4}%
  \setbeamercolor{block title alerted}{fg=UPESOrange,bg=UPESOrange!12}%
  \setbeamercolor{block body alerted}{fg=UPESBodyFG,bg=UPESOrange!5}%
  % Header navigation bar
  \setbeamercolor{section in head/foot}{fg=UPESBarFG,bg=UPESHeaderFooterBG}%
  \setbeamercolor{section in head/foot shaded}{fg=UPESBarFGInactive,bg=UPESHeaderFooterBG}%
  \setbeamercolor{subsection in head/foot}{fg=UPESBarFG,bg=UPESHeaderFooterBG}%
  \setbeamercolor{subsection in head/foot shaded}{fg=UPESBarFGInactive,bg=UPESHeaderFooterBG}%
  \setbeamercolor{upper separation line head}{bg=UPESHeaderFooterBG}%
  \setbeamercolor{middle separation line head}{bg=UPESHeaderFooterBG}%
  \setbeamercolor{lower separation line head}{bg=UPESHeaderFooterBG}%
  % Footer bar
  \setbeamercolor{upper separation line foot}{bg=UPESHeaderFooterBG}%
  \setbeamercolor{lower separation line foot}{bg=UPESHeaderFooterBG}%
  \setbeamercolor{author in head/foot}{fg=UPESBarFG,bg=UPESHeaderFooterBG}%
  \setbeamercolor{title in head/foot}{fg=UPESBarFG,bg=UPESHeaderFooterBG}%
  \setbeamercolor{institute in head/foot}{fg=UPESBarFG,bg=UPESHeaderFooterBG}%
  \setbeamercolor{page number in head/foot}{fg=UPESBarFG,bg=UPESHeaderFooterBG}%
}

\makeatletter
\newcommand{\UPESSetPalette}[1]{%
  \@ifundefined{UPES@palette@#1}{%
    \PackageWarning{beamerthemeUPES}{Unknown palette `#1'. Using `scheme01-classic-teal`.}%
    \csname UPES@palette@scheme01-classic-teal\endcsname%
  }{%
    \csname UPES@palette@#1\endcsname%
  }%
  \UPESApplyPalette%
}

