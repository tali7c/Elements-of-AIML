% --- Component scheme control ----------------------------------------------------
% Users can mix-and-match the core visual aspects without touching the .sty.
%
% In your `.tex`:
%   \usetheme[
%     headerfooter=brand-blue,
%     heading=teal,
%     bodyheadings=brand-blue,
%     bodytext=graphite
%   ]{UPES}
%
% You can also set these after `\usetheme{UPES}` using the corresponding macros.

\newcommand{\UPESSetHeaderFooterScheme}[1]{%
  \@ifundefined{UPES@hf@#1}{%
    \PackageWarning{beamerthemeUPES}{Unknown header/footer scheme `#1'. Using `brand-blue`.}%
    \csname UPES@hf@brand-blue\endcsname%
  }{%
    \csname UPES@hf@#1\endcsname%
  }%
  \UPESApplyPalette%
}
\newcommand{\UPESSetHeadingScheme}[1]{%
  \@ifundefined{UPES@heading@#1}{%
    \PackageWarning{beamerthemeUPES}{Unknown heading scheme `#1'. Using `teal`.}%
    \csname UPES@heading@teal\endcsname%
  }{%
    \csname UPES@heading@#1\endcsname%
  }%
  \UPESApplyPalette%
}
\newcommand{\UPESSetBodyHeadingsScheme}[1]{%
  \@ifundefined{UPES@bodyheadings@#1}{%
    \PackageWarning{beamerthemeUPES}{Unknown body headings scheme `#1'. Using `brand-blue`.}%
    \csname UPES@bodyheadings@brand-blue\endcsname%
  }{%
    \csname UPES@bodyheadings@#1\endcsname%
  }%
  \UPESApplyPalette%
}
\newcommand{\UPESSetBodyTextScheme}[1]{%
  \@ifundefined{UPES@bodytext@#1}{%
    \PackageWarning{beamerthemeUPES}{Unknown body text scheme `#1'. Using `graphite`.}%
    \csname UPES@bodytext@graphite\endcsname%
  }{%
    \csname UPES@bodytext@#1\endcsname%
  }%
  \UPESApplyPalette%
}

